# PostgreSQL bağlantısı (VPS'teki yerel veritabanı)
DATABASE_URL=postgresql://wpanel_user:wpanel_pass@localhost:5432/wpanel

# Redis (yerel)
REDIS_URL=redis://localhost:6379

# API portu
PORT=3001

# JWT imzalama secret'ı (openssl rand -hex 32 ile üretin, zorunludur)
JWT_SECRET=

# DB'de saklanan hassas verileri şifrelemek için (openssl rand -hex 32 ile üretin, zorunludur)
ENCRYPTION_KEY=

# İlk kurulumda oluşturulacak admin şifresi (boş bırakılırsa rastgele üretilip loglanır)
ADMIN_PASSWORD=

# 9Proxy kimlik bilgileri
PROXY_API_KEY=9proxy_api_key_buraya
PROXY_USERNAME=kullanici_adi
PROXY_PASSWORD=sifre

# WhatsApp session dosyaları dizini
SESSION_DIR=./sessions
